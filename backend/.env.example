PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/quickdata_auth

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM="QuickData GH <no-reply@quickdata.store>"
CORS_ORIGINS=http://localhost:8080,https://www.quickdata.store

OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
RESET_SESSION_MINUTES=15
BCRYPT_SALT_ROUNDS=12
